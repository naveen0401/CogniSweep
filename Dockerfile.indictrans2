FROM python:3.11-slim@sha256:ae52c5bef62a6bdd42cd1e8dffef86b9cd284bde9427da79839de7a4b983e7ca

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    HF_HOME=/models/huggingface \
    TRANSFORMERS_CACHE=/models/huggingface \
    INDICTRANS2_FORCE_CPU=true \
    PORT=8000

RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl ca-certificates build-essential \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements_indictrans2_worker.txt /app/requirements_indictrans2_worker.txt

# CPU-only Torch avoids pulling CUDA wheels into the worker image.
RUN python -m pip install --upgrade pip==26.1.2 \
    && python -m pip install --no-cache-dir --index-url https://download.pytorch.org/whl/cpu torch==2.12.0 \
    && python -m pip install --no-cache-dir -r /app/requirements_indictrans2_worker.txt

COPY indictrans2_worker.py /app/indictrans2_worker.py

EXPOSE 8000

CMD ["sh", "-c", "uvicorn indictrans2_worker:app --host 0.0.0.0 --port ${PORT:-8000}"]
