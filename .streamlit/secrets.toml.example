# CogniSweep Streamlit secrets template
# Copy these values into Streamlit Cloud -> App -> Settings -> Secrets.
# Do not rename this file to secrets.toml inside git, and never commit real keys.

COGNISWEEP_ENV = "production"
COGNISWEEP_ENFORCE_PUBLIC_LAUNCH_PREFLIGHT = "true"
COGNISWEEP_PUBLIC_BASE_URL = "https://app.cognisweep.com"
COGNISWEEP_SESSION_SECRET = "replace-with-a-long-random-secret"
COGNISWEEP_LANGUAGE_RESOURCE_MASTER_KEY = "replace-with-a-separate-long-random-secret-for-encrypted-resource-api-keys"

# Auth bootstrap credentials
# Generate hashes with: python deploy/auth_session_check.py --generate-password-hash
# Or read a password from an env var with: python deploy/auth_session_check.py --password-env COGNISWEEP_OWNER_BOOTSTRAP_PASSWORD
COGNISWEEP_OWNER_USERNAME = "owner@cognisweep.com"
COGNISWEEP_OWNER_PASSWORD_HASH = "replace-with-owner-pbkdf2-hash"
COGNISWEEP_USER_USERNAME = "workspace-owner@cognisweep.com"
COGNISWEEP_USER_PASSWORD_HASH = "replace-with-workspace-pbkdf2-hash"
COGNISWEEP_ORG_NAME = "replace-with-initial-workspace-name"
COGNISWEEP_DEFAULT_USER_ROLE = "Workspace Owner"

# Platform AI fallback. BYO user keys still take priority at runtime.
# For private env files, use deploy/ai_fallback_check.py --write-ai-env to avoid hand-editing secret values.
OPENAI_API_KEY = ""
COGNISWEEP_OPENAI_DEFAULT_MODEL = "gpt-4o-mini"
GEMINI_API_KEY = ""
COGNISWEEP_MANAGED_AI_ENABLED = "false"
COGNISWEEP_MANAGED_AI_BASE_URL = ""
COGNISWEEP_MANAGED_AI_API_KEY = ""
COGNISWEEP_MANAGED_AI_MODEL = "cognisweep-managed"

# Supabase persistence
# For private env files, use deploy/supabase_schema_check.py --write-supabase-env to avoid hand-editing key values.
SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_ANON_KEY = "replace-with-anon-key"
SUPABASE_SERVICE_ROLE_KEY = "replace-with-service-role-key"

# Object storage: choose Supabase Storage, S3, or GCS.
COGNISWEEP_OBJECT_STORAGE_PROVIDER = "supabase"
COGNISWEEP_OBJECT_STORAGE_ALLOW_PUBLIC_URLS = "false"
SUPABASE_STORAGE_BUCKET = "cognisweep-files"
# S3_BUCKET = ""
# AWS_REGION = "ap-south-1"
# S3_ENDPOINT_URL = ""
# GCS_BUCKET = ""

# Async worker handoff
COGNISWEEP_ASYNC_WORKER_URL = "https://worker.cognisweep.com/tasks"
COGNISWEEP_ASYNC_WORKER_TOKEN = "replace-with-worker-token"
COGNISWEEP_ASYNC_WORKER_SERVICE_ENABLED = "true"
COGNISWEEP_ASYNC_PROCESSOR_ENABLED = "true"
COGNISWEEP_WORKER_SUPERVISOR_ENABLED = "true"

# Billing
# For private env files, use deploy/launch_env_check.py --write-billing-env to avoid hand-editing key values.
COGNISWEEP_BILLING_PROVIDER = "razorpay"
COGNISWEEP_BILLING_WEBHOOK_RECEIVER_URL = "https://billing.cognisweep.com/webhooks/billing/razorpay"
COGNISWEEP_BILLING_WEBHOOK_SECRET = ""
RAZORPAY_KEY_ID = ""
RAZORPAY_KEY_SECRET = ""
RAZORPAY_WEBHOOK_SECRET = ""
RAZORPAY_PLAN_ID_PRO = ""
RAZORPAY_PLAN_ID_AGENCY = ""
COGNISWEEP_MONTHLY_MANDATE_LINK_TRIAL = ""
COGNISWEEP_MONTHLY_MANDATE_LINK_PRO = ""
COGNISWEEP_MONTHLY_MANDATE_LINK_AGENCY = ""
COGNISWEEP_MONTHLY_MANDATE_LINK_ENTERPRISE = ""
# STRIPE_SECRET_KEY = ""
# STRIPE_WEBHOOK_SECRET = ""
# STRIPE_PRICE_ID_PRO = ""
# STRIPE_PRICE_ID_AGENCY = ""
COGNISWEEP_BILLING_CREATE_PROVIDER_CHECKOUT = "false"

# Transactional email
# SES uses AWS SES SMTP credentials, not IAM access keys.
COGNISWEEP_EMAIL_PROVIDER = "ses"
COGNISWEEP_EMAIL_FROM = "no-reply@cognisweep.com"
COGNISWEEP_EMAIL_DISPATCH_WORKER_ENABLED = "true"
COGNISWEEP_AWS_SES_REGION = "ap-south-1"
SMTP_HOST = "email-smtp.ap-south-1.amazonaws.com"
SMTP_PORT = "587"
AWS_SES_SMTP_USERNAME = ""
AWS_SES_SMTP_PASSWORD = ""
SMTP_TLS = "true"
# RESEND_API_KEY = ""
# SENDGRID_API_KEY = ""

# Legal, edge, and backups
COGNISWEEP_LEGAL_REVIEWED = "false"
COGNISWEEP_WAF_PROVIDER = "cloudflare"
COGNISWEEP_BACKUP_PROVIDER = "supabase-pitr-and-storage-lifecycle"
COGNISWEEP_BACKUP_WORKER_ENABLED = "true"
COGNISWEEP_BACKUP_INTERVAL_HOURS = "24"
COGNISWEEP_BACKUP_RETENTION_DAYS = "30"
COGNISWEEP_BACKUP_OBJECT_STORAGE_ENABLED = "true"
COGNISWEEP_BACKUP_OUTPUT_DIR = "/data/cognisweep/backups"

# Future managed MT. Leave disabled until the Amazon Translate adapter is implemented.
COGNISWEEP_MT_PROVIDER = "disabled"
# COGNISWEEP_AWS_TRANSLATE_REGION = "ap-south-1"
# COGNISWEEP_AWS_TRANSLATE_USE_BATCH = "false"
# COGNISWEEP_AWS_TRANSLATE_TERMINOLOGY_NAMES = ""
