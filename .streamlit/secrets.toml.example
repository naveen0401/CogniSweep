# CogniSweep Streamlit secrets template
# Copy these values into Streamlit Cloud -> App -> Settings -> Secrets.
# Do not rename this file to secrets.toml inside git, and never commit real keys.

ERRORSWEEP_ENV = "production"
ERRORSWEEP_ENFORCE_PUBLIC_LAUNCH_PREFLIGHT = "true"
ERRORSWEEP_PUBLIC_BASE_URL = "https://app.cognisweep.com"
ERRORSWEEP_SESSION_SECRET = "replace-with-a-long-random-secret"

# Auth bootstrap credentials
# Generate hashes with: python deploy/auth_session_check.py --generate-password-hash
# Or read a password from an env var with: python deploy/auth_session_check.py --password-env ERRORSWEEP_OWNER_BOOTSTRAP_PASSWORD
ERRORSWEEP_OWNER_USERNAME = "owner@cognisweep.com"
ERRORSWEEP_OWNER_PASSWORD_HASH = "replace-with-owner-pbkdf2-hash"
ERRORSWEEP_USER_USERNAME = "workspace-owner@cognisweep.com"
ERRORSWEEP_USER_PASSWORD_HASH = "replace-with-workspace-pbkdf2-hash"
ERRORSWEEP_ORG_NAME = "replace-with-initial-workspace-name"
ERRORSWEEP_DEFAULT_USER_ROLE = "Workspace Owner"

# Platform AI fallback. BYO user keys still take priority at runtime.
# For private env files, use deploy/ai_fallback_check.py --write-ai-env to avoid hand-editing secret values.
OPENAI_API_KEY = ""
ERRORSWEEP_OPENAI_DEFAULT_MODEL = "gpt-4o-mini"
GEMINI_API_KEY = ""
ERRORSWEEP_MANAGED_AI_ENABLED = "false"
ERRORSWEEP_MANAGED_AI_BASE_URL = ""
ERRORSWEEP_MANAGED_AI_API_KEY = ""
ERRORSWEEP_MANAGED_AI_MODEL = "cognisweep-managed"

# Supabase persistence
# For private env files, use deploy/supabase_schema_check.py --write-supabase-env to avoid hand-editing key values.
SUPABASE_URL = "https://your-project.supabase.co"
SUPABASE_ANON_KEY = "replace-with-anon-key"
SUPABASE_SERVICE_ROLE_KEY = "replace-with-service-role-key"

# Object storage: choose Supabase Storage, S3, or GCS.
ERRORSWEEP_OBJECT_STORAGE_PROVIDER = "supabase"
ERRORSWEEP_OBJECT_STORAGE_ALLOW_PUBLIC_URLS = "false"
SUPABASE_STORAGE_BUCKET = "errorsweep-files"
# S3_BUCKET = ""
# AWS_REGION = "ap-south-1"
# S3_ENDPOINT_URL = ""
# GCS_BUCKET = ""

# Async worker handoff
ERRORSWEEP_ASYNC_WORKER_URL = "https://worker.cognisweep.com/tasks"
ERRORSWEEP_ASYNC_WORKER_TOKEN = "replace-with-worker-token"
ERRORSWEEP_ASYNC_WORKER_SERVICE_ENABLED = "true"
ERRORSWEEP_ASYNC_PROCESSOR_ENABLED = "true"
ERRORSWEEP_WORKER_SUPERVISOR_ENABLED = "true"

# Billing
# For private env files, use deploy/launch_env_check.py --write-billing-env to avoid hand-editing key values.
ERRORSWEEP_BILLING_PROVIDER = "razorpay"
ERRORSWEEP_BILLING_WEBHOOK_RECEIVER_URL = "https://billing.cognisweep.com/webhooks/billing/razorpay"
ERRORSWEEP_BILLING_WEBHOOK_SECRET = ""
RAZORPAY_KEY_ID = ""
RAZORPAY_KEY_SECRET = ""
RAZORPAY_WEBHOOK_SECRET = ""
RAZORPAY_PLAN_ID_PRO = ""
RAZORPAY_PLAN_ID_AGENCY = ""
# STRIPE_SECRET_KEY = ""
# STRIPE_WEBHOOK_SECRET = ""
# STRIPE_PRICE_ID_PRO = ""
# STRIPE_PRICE_ID_AGENCY = ""
ERRORSWEEP_BILLING_CREATE_PROVIDER_CHECKOUT = "false"

# Transactional email
ERRORSWEEP_EMAIL_PROVIDER = "resend"
ERRORSWEEP_EMAIL_FROM = "no-reply@cognisweep.com"
ERRORSWEEP_EMAIL_DISPATCH_WORKER_ENABLED = "true"
RESEND_API_KEY = ""
# SENDGRID_API_KEY = ""
# SMTP_HOST = ""
# SMTP_PORT = "587"
# SMTP_USER = ""
# SMTP_PASSWORD = ""
# SMTP_TLS = "true"

# Legal, edge, and backups
ERRORSWEEP_LEGAL_REVIEWED = "false"
ERRORSWEEP_WAF_PROVIDER = "cloudflare"
ERRORSWEEP_BACKUP_PROVIDER = "supabase-pitr-and-storage-lifecycle"
ERRORSWEEP_BACKUP_WORKER_ENABLED = "true"
ERRORSWEEP_BACKUP_INTERVAL_HOURS = "24"
ERRORSWEEP_BACKUP_RETENTION_DAYS = "30"
ERRORSWEEP_BACKUP_OBJECT_STORAGE_ENABLED = "true"
ERRORSWEEP_BACKUP_OUTPUT_DIR = "/data/errorsweep/backups"

# Self-hosted MT endpoints for no-key Pro translation
# Active default route is now IndicTrans2 + OPUS-MT. MADLAD is optional and disabled unless included in SELF_HOSTED_MT_ACTIVE_ENGINES.
SELF_HOSTED_MT_ACTIVE_ENGINES = "indictrans2,opus"
SELF_HOSTED_MT_DISABLE_INDIC = "false"
SELF_HOSTED_MT_DISABLE_OPUS = "false"
SELF_HOSTED_MT_DISABLE_MADLAD = "true"
INDICTRANS2_ENDPOINT = "https://mt.cognisweep.com/indictrans2/translate"
INDICTRANS2_API_KEY = "replace-with-indictrans2-worker-token"
OPUS_MT_ENDPOINT = "https://mt.cognisweep.com/opus/translate"
OPUS_MT_API_KEY = "replace-with-opus-worker-token"
MADLAD_ENDPOINT = "https://mt.cognisweep.com/madlad/translate"
MADLAD_API_KEY = "replace-with-madlad-worker-token"
SELF_HOSTED_MT_TIMEOUT = "300"
SELF_HOSTED_MT_ALLOW_PRIVATE_ENDPOINTS = "false"
