# CogniSweep production environment example
# Copy this file to deploy/.env.production and fill real values outside git.

COGNISWEEP_ENV=production
COGNISWEEP_ENFORCE_PUBLIC_LAUNCH_PREFLIGHT=true
COGNISWEEP_PUBLIC_BASE_URL=https://app.your-domain.com
COGNISWEEP_SESSION_SECRET=replace-with-a-long-random-secret
COGNISWEEP_LANGUAGE_RESOURCE_MASTER_KEY=replace-with-a-separate-long-random-secret-for-encrypted-resource-api-keys

# Auth bootstrap credentials
# Generate hashes with: python deploy/auth_session_check.py --generate-password-hash
# Or read from env vars and write this file with:
# python deploy/auth_session_check.py --env-file deploy/.env.production --write-bootstrap-env --owner-email owner@your-domain.com --workspace-email workspace-owner@your-domain.com --workspace-name "Your Workspace" --owner-password-env COGNISWEEP_OWNER_BOOTSTRAP_PASSWORD --workspace-password-env COGNISWEEP_WORKSPACE_BOOTSTRAP_PASSWORD
COGNISWEEP_OWNER_USERNAME=owner@your-domain.com
COGNISWEEP_OWNER_PASSWORD_HASH=replace-with-owner-pbkdf2-hash
COGNISWEEP_USER_USERNAME=workspace-owner@your-domain.com
COGNISWEEP_USER_PASSWORD_HASH=replace-with-workspace-pbkdf2-hash
COGNISWEEP_ORG_NAME=replace-with-initial-workspace-name
COGNISWEEP_DEFAULT_USER_ROLE=Workspace Owner

# Streamlit and local container storage paths
COGNISWEEP_EDITOR_JOB_DIR=/data/cognisweep/editor_jobs
COGNISWEEP_JOB_ATTACHMENT_DIR=/data/cognisweep/job_attachments
COGNISWEEP_OBJECT_STORAGE_DIR=/data/cognisweep/object_storage

# Supabase persistence
# Write Supabase persistence + Supabase Storage settings with:
# python deploy/supabase_schema_check.py --env-file deploy/.env.production --write-supabase-env --supabase-url https://your-project.supabase.co --anon-key-env SUPABASE_ANON_KEY --service-role-key-env SUPABASE_SERVICE_ROLE_KEY --storage-bucket cognisweep-files
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=replace-with-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Platform AI fallback: BYO user keys are preferred at runtime.
# Configure either OPENAI_API_KEY or a live managed OpenAI-compatible/vLLM endpoint.
# OpenAI route setup:
# python deploy/ai_fallback_check.py --env-file deploy/.env.production --write-ai-env --ai-route openai --openai-key-env OPENAI_API_KEY --model gpt-4o-mini
# Managed route setup:
# python deploy/ai_fallback_check.py --env-file deploy/.env.production --write-ai-env --ai-route managed --managed-base-url https://ai.your-domain.com/v1 --managed-api-key-env COGNISWEEP_MANAGED_AI_TOKEN --managed-model your-model
OPENAI_API_KEY=
COGNISWEEP_OPENAI_DEFAULT_MODEL=gpt-4o-mini
GEMINI_API_KEY=
COGNISWEEP_MANAGED_AI_ENABLED=false
COGNISWEEP_MANAGED_AI_BASE_URL=
COGNISWEEP_MANAGED_AI_API_KEY=
COGNISWEEP_MANAGED_AI_MODEL=cognisweep-managed

# Object storage: choose supabase, s3, or gcs
COGNISWEEP_OBJECT_STORAGE_PROVIDER=supabase
COGNISWEEP_OBJECT_STORAGE_ALLOW_PUBLIC_URLS=false
SUPABASE_STORAGE_BUCKET=cognisweep-files
# S3_BUCKET=
# AWS_REGION=ap-south-1
# S3_ENDPOINT_URL=
# GCS_BUCKET=

# Async worker handoff and receiver
COGNISWEEP_ASYNC_WORKER_URL=http://errorsweep-async-receiver:8300/tasks
COGNISWEEP_ASYNC_WORKER_TOKEN=replace-with-worker-token
COGNISWEEP_ASYNC_WORKER_SERVICE_ENABLED=true
COGNISWEEP_ASYNC_WORKER_REQUIRE_TOKEN=true
COGNISWEEP_ASYNC_WORKER_HOST=0.0.0.0
COGNISWEEP_ASYNC_WORKER_PORT=8300
COGNISWEEP_ASYNC_WORKER_DIR=/data/cognisweep/async_worker
COGNISWEEP_ASYNC_PROCESSOR_ENABLED=true
COGNISWEEP_ASYNC_PROCESS_ON_ACCEPT=false
COGNISWEEP_ASYNC_PROCESSOR_INTERVAL=10
COGNISWEEP_ASYNC_RESULT_DIR=/data/cognisweep/async_results
# REDIS_URL=
# CELERY_BROKER_URL=

# Worker supervisor
COGNISWEEP_WORKER_SUPERVISOR_ENABLED=true
COGNISWEEP_SUPERVISOR_ENABLE_ASYNC_PROCESSOR=true
COGNISWEEP_SUPERVISOR_ENABLE_EMAIL_WORKER=true
COGNISWEEP_SUPERVISOR_ENABLE_BACKUP_WORKER=true
COGNISWEEP_SUPERVISOR_ENABLE_BILLING_RECEIVER=false
COGNISWEEP_SUPERVISOR_POLL_SECONDS=10
COGNISWEEP_SUPERVISOR_LOG_DIR=/logs/cognisweep/supervisor
COGNISWEEP_SUPERVISOR_STATUS_FILE=/logs/cognisweep/supervisor/status.json

# Billing: choose stripe or razorpay
# Razorpay setup:
# python deploy/launch_env_check.py --env-file deploy/.env.production --write-billing-env --billing-provider razorpay --billing-webhook-url https://billing.your-domain.com/webhooks/billing/razorpay --razorpay-key-id-env RAZORPAY_KEY_ID --razorpay-key-secret-env RAZORPAY_KEY_SECRET --razorpay-webhook-secret-env RAZORPAY_WEBHOOK_SECRET --pro-plan-id plan_pro --agency-plan-id plan_agency
# Stripe setup:
# python deploy/launch_env_check.py --env-file deploy/.env.production --write-billing-env --billing-provider stripe --billing-webhook-url https://billing.your-domain.com/webhooks/billing/stripe --stripe-secret-key-env STRIPE_SECRET_KEY --stripe-webhook-secret-env STRIPE_WEBHOOK_SECRET --pro-plan-id price_pro --agency-plan-id price_agency
COGNISWEEP_BILLING_PROVIDER=razorpay
COGNISWEEP_BILLING_WEBHOOK_SECRET=
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
COGNISWEEP_BILLING_WEBHOOK_RECEIVER_URL=https://billing.your-domain.com/webhooks/billing/razorpay
COGNISWEEP_BILLING_WEBHOOK_HOST=0.0.0.0
COGNISWEEP_BILLING_WEBHOOK_PORT=8301
COGNISWEEP_WEBHOOK_APPLY_UPDATES=true
RAZORPAY_PLAN_ID_PRO=
RAZORPAY_PLAN_ID_AGENCY=
RAZORPAY_PLAN_ID_ENTERPRISE=
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID_PRO=
# STRIPE_PRICE_ID_AGENCY=
# STRIPE_PRICE_ID_ENTERPRISE=
COGNISWEEP_BILLING_CREATE_PROVIDER_CHECKOUT=false
COGNISWEEP_MONTHLY_MANDATE_LINK_PRO=
COGNISWEEP_MONTHLY_MANDATE_LINK_AGENCY=
COGNISWEEP_MONTHLY_MANDATE_LINK_ENTERPRISE=
COGNISWEEP_TRIAL_MANDATE_LINK=

# Transactional email: choose resend, sendgrid, or smtp
COGNISWEEP_EMAIL_PROVIDER=resend
COGNISWEEP_EMAIL_HTML_ENABLED=true
COGNISWEEP_EMAIL_DISPATCH_WORKER_ENABLED=true
COGNISWEEP_EMAIL_WORKER_INTERVAL_SECONDS=60
COGNISWEEP_EMAIL_DISPATCH_BATCH_LIMIT=25
COGNISWEEP_EMAIL_FROM=no-reply@your-domain.com
RESEND_API_KEY=
# SENDGRID_API_KEY=
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_TLS=true

# Enterprise SSO and legal launch flags
COGNISWEEP_ENTERPRISE_SSO_ENABLED=false
COGNISWEEP_SSO_PROVIDER=okta
COGNISWEEP_SSO_PROTOCOL=OIDC
COGNISWEEP_SSO_WORKSPACE=Enterprise Workspace
COGNISWEEP_SSO_DOMAINS=customer.com
COGNISWEEP_SSO_ISSUER_URL=
COGNISWEEP_SSO_CLIENT_ID=
COGNISWEEP_SSO_REDIRECT_URI=https://app.your-domain.com/?public=sso_handoff
COGNISWEEP_SSO_LOGIN_URL=
COGNISWEEP_SSO_HANDOFF_SECRET=replace-with-long-random-shared-secret
COGNISWEEP_LEGAL_REVIEWED=false
COGNISWEEP_WAF_PROVIDER=cloudflare

# Backup worker
COGNISWEEP_BACKUP_PROVIDER=supabase-pitr-and-storage-lifecycle
COGNISWEEP_BACKUP_WORKER_ENABLED=true
COGNISWEEP_BACKUP_INTERVAL_HOURS=24
COGNISWEEP_BACKUP_RETENTION_DAYS=30
COGNISWEEP_BACKUP_OBJECT_STORAGE_ENABLED=true
COGNISWEEP_BACKUP_OUTPUT_DIR=/data/cognisweep/backups

# Self-hosted MT endpoints for no-key translation
INDICTRANS2_ENDPOINT=https://mt.your-domain.com/indictrans2/translate
INDICTRANS2_API_KEY=replace-with-indictrans2-worker-token
MADLAD_ENDPOINT=https://mt.your-domain.com/madlad/translate
MADLAD_API_KEY=replace-with-madlad-worker-token
OPUS_MT_ENDPOINT=https://mt.your-domain.com/opus/translate
OPUS_MT_API_KEY=replace-with-opus-worker-token
SELF_HOSTED_MT_TIMEOUT=300
SELF_HOSTED_MT_ALLOW_PRIVATE_ENDPOINTS=false

# Smoke/preflight
COGNISWEEP_SMOKE_TEST_LOG_LEVEL=WARNING
