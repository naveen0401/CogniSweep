{$COGNISWEEP_DOMAIN:cognisweep.com}, {$COGNISWEEP_WWW_DOMAIN:www.cognisweep.com} {
    encode gzip zstd

    header {
        >Content-Security-Policy "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; form-action 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; font-src 'self' data:; connect-src 'self' https: wss: ws: blob:; media-src 'self' data: blob: https:; frame-src 'self' blob: data: https://www.youtube.com https://www.youtube-nocookie.com; worker-src 'self' blob:"
        >Strict-Transport-Security "max-age=31536000; includeSubDomains"
        >X-Frame-Options "SAMEORIGIN"
        >X-Content-Type-Options "nosniff"
        >Referrer-Policy "strict-origin-when-cross-origin"
        >Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
        >Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
        >Pragma "no-cache"
        >Expires "0"
        >Set-Cookie "^(_streamlit_xsrf=[^;]+; Path=/; SameSite=Lax)$" "$1; Secure"
    }

    route {
        @shareAsset path /cognisweep-logo.png
        handle @shareAsset {
            root * /srv/cognisweep-assets
            file_server
        }

        @socialPreview {
            path / /solutions/software-localization-tool
            header_regexp User-Agent (?i)(WhatsApp|facebookexternalhit|Facebot|Twitterbot|LinkedInBot|Slackbot|Discordbot|TelegramBot|SkypeUriPreview|Googlebot|Bingbot)
        }
        handle @socialPreview {
            root * /srv/cognisweep-public
            rewrite * /share-preview.html
            file_server
        }

        @apexLanding {
            host {$COGNISWEEP_DOMAIN:cognisweep.com}
            path /
            query ""
        }
        redir @apexLanding https://{$COGNISWEEP_WWW_DOMAIN:www.cognisweep.com}/solutions/software-localization-tool 308

        @wwwRootLanding {
            host {$COGNISWEEP_WWW_DOMAIN:www.cognisweep.com}
            path /
            query ""
        }
        redir @wwwRootLanding /solutions/software-localization-tool 308

        @billing path /webhooks/billing/*
        reverse_proxy @billing errorsweep-billing-webhook:8301

        reverse_proxy errorsweep-app:8501
    }
}
